Program File Format Version : 1.6   ' 프로그램 파일 포맷 버전
MechType: 389(HS180-02)             ' 로봇 기종 (HS180-02)
TotalAxis: 6                        ' 6축 로봇
AuxAxis: 0                          ' 보조축 없음

'Vision start
'==================================
' 비전 시스템 연동 시작
'==================================
*START
DELAY 0.1                            ' 0.1초 대기
ENET1.IP="192.168.10.101"            ' ENET1의 IP 주소 설정
ENET1.RPORT=2000                     ' 원격(Remote) 포트 설정
ENET1.LPORT=2000                     ' 로컬(Local) 포트 설정
ENET1.OPEN 1                         ' ENET1 통신 포트 오픈

_TEINPUT=13                          ' ASCII CR(Carriage Return) = 13
_TEINPUT=10                          ' ASCII LF(Line Feed) = 10
CLR_RBUF ENET1                       ' ENET1 수신 버퍼 초기화
IF ENET1.STATE<1 THEN *START          ' 통신 안되면 다시 START로 점프

'==================================
' 준비 신호 송신 & 문자열 초기화
'==================================
V1$=""                               ' 수신 문자열 변수
V2$=""                               ' 변환 문자열 변수
DELAY 0.2
PRINT ENET1,"READY";V201$;""         ' 비전 시스템에 READY 신호 전송
PRINT #0,V201$                       ' 디버그용 콘솔 출력
DELAY 0.4
V1$=""                               ' 수신 문자열 초기화

'==================================
' 데이터 수신 및 헤더 체크
'==================================
*CHECK
INPUT ENET1,V1$,10,*CHECK             ' ENET1으로부터 문자열 V1$ 수신
V600%=VAL(MID$(V1$,1,10))            ' 앞 10자리 → 정수 변환 → V600%에 저장
IF V600%<>1100 THEN *ERROR           ' 헤더값이 1100이 아니면 에러

'==================================
*CHECK1
V600!=VAL(MID$(V1$,6,4))             ' V1$의 6번째부터 4자리 → 실수 변환 → V600!
                                     ' (비전에서 보낸 포즈 개수)

'==================================
FOR LV1%=1 TO V600!*6                ' 포즈 개수 × 6 만큼 반복
    V![LV1%]=0                       ' 좌표값 배열 V![ ] 초기화
NEXT

'==================================
*CHECK3
FOR LV1%=1 TO V600!*6
    V![LV1%]=VAL(MID$(V1$,11+((LV1%-1)*8),10))
                                     ' V1$에서 좌표값들을 8자리 단위로 읽어 V![ ]에 저장
NEXT

'==================================
FOR V1%=1 TO V600!
    P[V1%]=(V![((V1%*6)-5)/1],       ' X 좌표
            V![((V1%*6)-4)/1],       ' Y 좌표
            V![((V1%*6)-3)/1],       ' Z 좌표
            V![((V1%*6)-2)/1],       ' Rx (Roll)
            V![((V1%*6)-1)/1],       ' Ry (Pitch)
            V![(V1%*6)/1])A          ' Rz (Yaw)
                                     ' 포즈 P[V1%] = (X,Y,Z,Rx,Ry,Rz) 절대좌표(A)로 정의
NEXT
V1%=V1%-2                            ' 인덱스 보정 (이전 포즈부터 시작하려는 의도 추정)

'==================================
S1   MOVE P,P[V1%],S=5%,A=0,T=21     ' P[V1%] 포인트로 이동 (속도 5%, 툴 21)
     IF V1%>=V600! THEN *END         ' 마지막 포즈면 END로 이동

S2   MOVE P,P[V1%+1],S=5%,A=0,T=21   ' 다음 포즈 이동
     IF V1%+1>=V600! THEN *END       ' 마지막 포즈면 END

S3   MOVE P,P[V1%+2],S=5%,A=0,T=21   ' 다다음 포즈 이동
     IF V1%+2>=V600! THEN *END       ' 마지막 포즈면 END

'==================================
*END
END                                  ' 프로그램 종료

*ERROR
STOP                                 ' 에러 발생 시 로봇 정지
