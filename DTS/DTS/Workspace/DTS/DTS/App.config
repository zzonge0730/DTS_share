<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <add key="VISION_IP" value="172.21.135.200" />
        <add key="VISION_PORT" value="50001" />
        <add key="ROBOT_IP" value="172.21.135.200" />
        <add key="ROBOT_PORT" value="2000" />
        <add key="MY_IP" value="172.21.128.1" />
        <add key="MY_PORT" value="2001" />
        <add key="POSES_PER_PACKET" value="3" />
        <add key="PAD_LAST_PACKET" value="true" />
        <!-- 수신측 파서가 cnt를 패킷당 포즈수로 해석하므로 기본값은 packet -->
        <add key="CNT_FIELD_MODE" value="packet" />
        <add key="MAX_TOL" value="2.0" />
        <add key="AVG_TOL" value="1.0" />
        <!-- Required deployment guardrail: startup fails closed if any pose bounds are missing or invalid. -->
        <!-- Pose safety bounds (robot workspace guardrail) -->
        <add key="X_MIN" value="-5000" />
        <add key="X_MAX" value="5000" />
        <add key="Y_MIN" value="-5000" />
        <add key="Y_MAX" value="5000" />
        <add key="Z_MIN" value="-5000" />
        <add key="Z_MAX" value="5000" />
        <add key="GAP_MODE" value="uniform" />
        <!-- 실측 Gap 입력(JSON). 상대경로면 DTS.exe 기준 경로로 해석 -->
        <add key="GAP_JSON_PATH" value="gap_input.json" />
        <!-- Gap JSON 타임스탬프 허용 최대 지연(ms) -->
        <add key="GAP_MAX_AGE_MS" value="5000" />
        <!-- true면 JSON 불가 시 기존 랜덤/더미 판정 사용 -->
        <add key="GAP_ALLOW_LEGACY_RANDOM" value="false" />
        <!-- ICP 품질 게이트: true면 fitness/rmse 기준 미달 시 NG -->
        <add key="ICP_QUALITY_ENFORCE" value="true" />
        <add key="ICP_FITNESS_MIN" value="0.3" />
        <add key="ICP_INLIER_RMSE_MAX" value="1.5" />
        <add key="STATUS_ENABLE" value="true" />
        <add key="STATUS_TARGET_IP" value="172.21.135.200" />
        <add key="STATUS_PORT" value="2002" />
        <add key="STATUS_COOLDOWN_MS" value="3000" />
        <add key="STATUS_RESEND_WHILE_LATCHED" value="false" />
        <add key="STATUS_SEND_ON_STATE_CHANGE" value="true" />
    </appSettings>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
</configuration>
